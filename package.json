{
  "name": "device-management-system",
  "version": "1.0.0",
  "description": "售后登记系统 - 支持多类型设备管理、版本追踪、售后问题记录",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "start": "chcp 65001 > nul && node server/index.js",
    "init-db": "node -e \"require('./server/database').initializeDatabase().then(() => process.exit(0)).catch(() => process.exit(1))\""
  },
  "keywords": [
    "device-management",
    "version-control",
    "issue-tracking",
    "react",
    "nodejs",
    "mysql"
  ],
  "author": "Device Management System",
  "license": "MIT",
  "dependencies": {
    "ali-oss": "^6.18.0",
    "archiver": "^5.3.2",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
